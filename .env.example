# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Session Secret (optional) ─────────────────────────────────────────────────
# If not set, one is auto-generated and stored in the database.
# Only set this if you need sessions to survive a full database reset.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SESSION_SECRET=
